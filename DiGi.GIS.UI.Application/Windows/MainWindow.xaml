<Window x:Class="DiGi.GIS.UI.Application.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DiGi.GIS.UI.Application"
        xmlns:Controls="clr-namespace:DiGi.UI.WPF.Core.Controls;assembly=DiGi.UI.WPF.Core"
        mc:Ignorable="d"
        Title="GIS" Height="400" Width="600" ResizeMode="NoResize" Icon="/DiGi.GIS.ico">
    <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,5,0,0">
                <Button x:Name="Button_ToDiGiGISModelFiles" Content="Convert from BDOT10k" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_ToDiGiGISModelFiles_Click" />
                <Button x:Name="Button_CalculateGISModelFiles" Content="Calculate GISModels" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_CalculateGISModelFiles_Click" />
                <Button x:Name="Button_WriteStatisticalDataCollections" Content="Write StatisticalDataCollections" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_WriteStatisticalDataCollections_Click" Visibility="Visible" />
                <Button x:Name="Button_CalculateOrtoRanges" Content="Calculate OrtoRanges" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_CalculateOrtoRanges_Click" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,5,0,0">
                <Button x:Name="Button_CalculateOrtoDatas_Building2D" Content="Calculate OrtoDatas (Building2D)" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_CalculateOrtoDatas_Building2D_Click" />
                <Button x:Name="Button_CalculateOrtoDatas_OrtoRange" Content="Calculate OrtoDatas (OrtoRange)" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_CalculateOrtoDatas_OrtoRange_Click" />
                <Button x:Name="Button_ConvertOrtoDatasToFiles" Content="Convert OrtoDatas to files" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_ConvertOrtoDatasToFiles_Click" />
                <Button x:Name="Button_ResaveOrtoDatasFiles" Content="Resave OrtoDatas Files" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_ResaveOrtoDatasFiles_Click"  IsEnabled="False" />
                <Button x:Name="Button_CalculateAdministrativeAreal2DStatisticalUnits" Content="Calculate StatisticalUnits" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_CalculateAdministrativeAreal2DStatisticalUnits_Click"  Visibility="Visible" />
                <Button x:Name="Button_CalculateOrtoDatasComparisons" Content="Calculate OrtoDatasComparisons" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_CalculateOrtoDatasComparisons_Click"  Visibility="Visible" IsEnabled="False" />
                <Button x:Name="Button_AppendYOLOModel" Content="Append YOLO Model" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_AppendYOLOModel_Click"   Visibility="Visible" />
                <Button x:Name="Button_AppendVoTTModel" Content="Append VoTT Model" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_AppendVoTTModel_Click"  Visibility="Visible" IsEnabled="False" />
                <Button x:Name="Button_AppendPredictions" Content="Append Predictions" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_AppendPredictions_Click"  Visibility="Visible" />
                <Button x:Name="Button_AppendTable" Content="Append Table (Machine Learing)" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_AppendTable_Click"  Visibility="Visible" />
                <Button x:Name="Button_AppendPredictionYearBuilts" Content="Append Prediction Year Builts" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_AppendPredictionYearBuilts_Click"  Visibility="Visible" />
                <Button x:Name="Button_AppendBuildingModels" Content="Append Building Models" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_AppendBuildingModels_Click"  Visibility="Visible" />
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="0,5,0,0">

                <Button x:Name="Button_YearBuilts" Content="Year Builts" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_YearBuilts_Click" />
                <Button x:Name="Button_OrtoDatas" Content="OrtoDatas" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_OrtoDatas_Click" />
                <Button x:Name="Button_Typology" Content="Typology" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_Typology_Click" Visibility="Visible" />
                <Button x:Name="Button_CalculateTypologies" Content="Calculate Typologies" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_CalculateTypologies_Click" Visibility="Visible" />
                <Button x:Name="Button_RecalculateOrtoDatas_Building2D" Content="Recalculate OrtoDatas (Building2D)" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_RecalculateOrtoDatas_Building2D_Click" Visibility="Visible" />
                <Button x:Name="Button_Test" Content="Test" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="190" Click="Button_Test_Click" Visibility="Visible" />
            </StackPanel>
        </Grid>
        <StatusBarItem DockPanel.Dock="Bottom" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="3,3,3,3">
            <TextBlock x:Name="TextBlock_Progress" Text="..." HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="3,0,0,0" />
        </StatusBarItem>
    </DockPanel>
</Window>