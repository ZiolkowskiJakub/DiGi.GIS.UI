<Window x:Class="DiGi.GIS.UI.Windows.TypologyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DiGi.GIS.UI.Windows"
        xmlns:Controls="clr-namespace:DiGi.UI.WPF.Core.Controls;assembly=DiGi.UI.WPF.Core"
        mc:Ignorable="d"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Typology" Height="1080" Width="1920" Loaded="Window_Loaded">
    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top">
            <Menu>
                <MenuItem Header="File">
                    <MenuItem x:Name="MenuItem_Load" Header="Load" Click="MenuItem_Load_Click"/>
                    <Separator/>
                    <MenuItem x:Name="MenuItem_Close" Header="Close" Click="MenuItem_Close_Click"/>
                </MenuItem>
                <MenuItem Header="Help">
                    <MenuItem x:Name="MenuItem_About" Header="About" Click="MenuItem_About_Click"/>
                </MenuItem>
            </Menu>
        </StackPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <Controls:ProgressBarControl x:Name="ProgressBarControl_Main" Width="300" VerticalAlignment="Center"/>
            </StatusBarItem>
        </StatusBar>
        <Grid DockPanel.Dock="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="600" MinWidth="350"/>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>
            <TabControl Grid.Column="0" TabStripPlacement="Bottom" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2,2,2,0">
                <TabItem Header="Typology">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="350"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4.5*"/>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="5.5*"/>
                            </Grid.ColumnDefinitions>
                            <Controls:TreeViewControl Grid.Row="0" x:Name="TreeViewControl_Typology" />
                            <GridSplitter Grid.Column="1" Width="5" VerticalAlignment="Stretch" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                            <ListBox Grid.Column="5" x:Name="ListBox_References" Margin="0,0,0,30"/>
                            <Label x:Name="Label_Count" Grid.Column="2" Content="Count: 0" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        </Grid>
                        <GridSplitter Grid.Row="1" Height="5" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="0,0,0,30"/>
                        <lvc:PieChart x:Name="PieChart_Main" Grid.Row="2" Series="{Binding Series}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" LegendLocation="Bottom"/>
                    </Grid>
                </TabItem>
            </TabControl>
            <GridSplitter Grid.Column="1" Width="5" VerticalAlignment="Stretch" HorizontalAlignment="Center"/>
            <TabControl Grid.Column="2" TabStripPlacement="Top"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,2,2,2">
                <TabItem Header="Building" >
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Orientation" Value="Vertical"/>
                                <Setter Property="Width" Value="30"/>
                            </Style>
                        </ScrollViewer.Resources>
                        <WrapPanel x:Name="WrapPanel_Main"  Orientation="Horizontal" Margin="10"/>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
